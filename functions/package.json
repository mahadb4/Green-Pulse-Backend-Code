{
  "name": "greenpulse-functions",
  "version": "1.0.0",
  "description": "GreenPulse — The Collaborative Carbon Garden backend",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": "20"
  },
  "private": true,
  "dependencies": {
    "@genkit-ai/core": "^1.33.0",
    "@genkit-ai/firebase": "^1.33.0",
    "@genkit-ai/google-genai": "^1.33.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.16.0",
    "firebase-admin": "^13.9.0",
    "firebase-functions": "^7.2.5",
    "genkit": "^1.33.0",
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "firebase-tools": "^15.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
