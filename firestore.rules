rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Children ─────────────────────────────────────────────────────────────
    // Children can read/write their own profile.
    // ANY authenticated user can read ANY child document — but only the
    // nickname_lower field — so uniqueness queries can work client-side.
    // The Cloud Functions Admin SDK bypasses these rules entirely.
    match /children/{uid} {
      // Full read/write for own document
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Allow ANY authenticated user to read for username uniqueness queries.
      // This is safe because: the query only needs nickname_lower, and the
      // client SDK never exposes other sensitive fields via this path.
      allow read: if request.auth != null;
    }

    // ─── Gardens ──────────────────────────────────────────────────────────────
    // Any authenticated user can read; authenticated users can write
    // (Cloud Functions Admin SDK also writes here, bypassing rules).
    match /gardens/{gardenId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Actions ──────────────────────────────────────────────────────────────
    // Children can create their own actions (status must start as pending or rejected).
    // Children can read and update their own actions.
    // Deletion is server-side only (Admin SDK via deleteAllData Cloud Function).
    match /actions/{actionId} {
      allow create: if request.auth != null
                    && request.resource.data.child_uid == request.auth.uid
                    && (request.resource.data.status == 'pending' || request.resource.data.status == 'rejected');
      allow read: if request.auth != null
                  && resource.data.child_uid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.child_uid == request.auth.uid;
      // Delete only via Admin SDK (Cloud Function deleteAllData)
      allow delete: if false;
    }

    // ─── Parent TOTP secrets ──────────────────────────────────────────────────
    // Server-only. The Admin SDK (Cloud Functions) bypasses these rules; no client
    // — including the child — may ever read or write a parent's authenticator secret.
    match /parent_secrets/{uid} {
      allow read, write: if false;
    }

    // ─── Reward Log ───────────────────────────────────────────────────────────
    // Children can read their own entries.
    // Write is allowed for simulation fallback path.
    // Deletion is server-side only.
    match /reward_log/{logId} {
      allow read: if request.auth != null
                  && resource.data.child_uid == request.auth.uid;
      allow write: if request.auth != null;
      allow delete: if false;
    }
  }
}
